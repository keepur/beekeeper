{
  "name": "@keepur/beekeeper",
  "version": "1.3.2",
  "description": "Claude Code session gateway — real development from your phone",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "beekeeper": "dist/cli.js",
    "beekeeperd": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "beekeeper.yaml.example",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@linear/sdk": "^39.2.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "ulid": "^3.0.2",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
