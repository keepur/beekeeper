# Public HTTP/WS port. Default 8420 — the shared public-facing port that
# fronts both Beekeeper and (optionally) Hive via the ?channel= query param.
# Hive's own loopback binding stays on 3200 forever; they do not collide.
port: 8420
model: claude-opus-4-6
default_workspace: my-project

# Capability manifest health-check tuning (optional; defaults shown).
# Beekeeper polls each registered capability's healthUrl on this interval,
# and drops the capability after this many consecutive failures.
# capabilities_health_interval_ms: 10000
# capabilities_failure_threshold: 2

workspaces:
  my-project: ~/code/my-project
  another: ~/code/another

confirm_operations:
  - "git push --force"
  - "git branch -D"
  - "rm -rf"
  - "rm -r"
  - "git reset --hard"
  - "git checkout -- ."
  - "git clean -f"

# Hive instances managed by this Beekeeper. Used by `beekeeper frame ...`.
# instanceId is the key; servicePath is the deployed instance directory.
# mongoUri defaults to mongodb://localhost:27017; dbName defaults to hive_<instanceId>.
instances:
  dodi:
    servicePath: /Users/youruser/services/hive/dodi
  keepur:
    servicePath: /Users/youruser/services/hive/keepur
